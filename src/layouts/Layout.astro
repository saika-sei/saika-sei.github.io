---
import BaseHead from '@/components/BaseHead.astro';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import type { PrimaryCategorySlug } from '@/data/site';
import '@/styles/global.css';

type Props = {
  title?: string;
  description?: string;
  activeCategory?: PrimaryCategorySlug;
  landing?: boolean;
};

const { title, description, activeCategory, landing = false } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class:list={[landing && 'landing-page']}>
    <Header activeCategory={activeCategory} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
